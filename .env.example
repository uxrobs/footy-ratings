# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: manual POST /api/sync/fixtures protection
CRON_SECRET=

# Auto-sync when pages load (minutes between Squiggle fetches). Default: 30
SYNC_INTERVAL_MINUTES=30

# Auto-advance to the next round when all games are complete (default: on)
AUTO_ADVANCE_ROUNDS=true

# Seed script overrides (optional)
SEED_YEAR=2026
SEED_ROUND=12
